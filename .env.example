# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
VITE_APP_NAME=MyApp
VITE_APP_VERSION=0.0.0

# ─────────────────────────────────────────────
# API
# ─────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3001/api/v1
VITE_API_TIMEOUT=10000

# ─────────────────────────────────────────────
# Auth
# ─────────────────────────────────────────────
VITE_AUTH_TOKEN_KEY=access_token
VITE_AUTH_REFRESH_TOKEN_KEY=refresh_token

# ─────────────────────────────────────────────
# External Services
# ─────────────────────────────────────────────
VITE_SENTRY_DSN=
VITE_ANALYTICS_WRITE_KEY=
VITE_FEATURE_FLAGS_KEY=
# PostHog project API key — get it from posthog.com → Project Settings → Project API Key
# Covers both analytics and feature flags in one key
VITE_POSTHOG_KEY=
# PostHog ingest host — us.i.posthog.com (US) or eu.i.posthog.com (EU)
VITE_POSTHOG_HOST=https://us.i.posthog.com

# ─────────────────────────────────────────────
# Build / Deploy
# ─────────────────────────────────────────────
VITE_ENABLE_MSW=false
